{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "crons": [
    {
      "path": "/api/cron/publish-due-posts",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "templates/**,node_modules/@sparticuz/chromium/**"
    }
  }
}
