# Frontend (Vite) — se embeben en el build
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Backend (NUNCA en frontend)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
SUPABASE_STORAGE_BUCKET=social-posts
SUPABASE_GALLERY_BUCKET=media-gallery

# Seguridad del cron
CRON_SECRET=genera-un-secreto-largo-y-aleatorio

# Meta / Facebook / Instagram
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v20.0

# OpenAI (opcional — de pago ~$0.04/imagen)
OPENAI_API_KEY=

# Google Gemini (opcional — GRATIS en aistudio.google.com)
GEMINI_API_KEY=

# TikTok (preparado)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google Business Profile (preparado)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App
APP_URL=https://tu-proyecto.vercel.app
PORT=3001
NODE_ENV=production

# Vercel: necesario para que Chromium encuentre sus librerías en serverless
AWS_LAMBDA_JS_RUNTIME=nodejs22.x

# Scripts locales (opcional)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cron local dev (opcional)
ENABLE_LOCAL_CRON=false
