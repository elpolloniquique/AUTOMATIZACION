# Frontend (Vite)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Backend (nunca exponer en frontend)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
SUPABASE_STORAGE_BUCKET=social-posts

# Seguridad del cron
CRON_SECRET=genera-un-secreto-largo-y-aleatorio

# Meta / Facebook / Instagram
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v20.0

# OpenAI (opcional - sin key funciona modo manual)
OPENAI_API_KEY=

# TikTok (preparado para cuando aprueben la API)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google Business Profile (preparado)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App
APP_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
